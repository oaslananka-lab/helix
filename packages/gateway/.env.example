PORT=3000
NODE_ENV=production
LOG_LEVEL=info

AGENT_KEYS_JSON={"home-pc-1":"change-this-secret-min-32-chars"}
INTERNAL_BEARER_TOKEN=change-this-bearer-token-min-32-chars

PUBLIC_URL=https://gateway.example.com
AGENT_AUTO_NAMESPACE=true
ALLOW_SINGLE_AGENT_NO_PREFIX=true
AGENT_CAPABILITY_CACHE_TTL_MS=60000
AGENT_CALL_TIMEOUT_MS=30000
AGENT_KEEPALIVE_INTERVAL_MS=15000

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AGENT_WS_MAX=10
DUPLICATE_AGENT_STRATEGY=kick_old

ENABLE_METRICS=true
SSE_KEEPALIVE_INTERVAL_MS=15000
SSE_KEEPALIVE_COMMENT=:keepalive

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
