AGENT_ID=home-pc-1
AGENT_NAME=Home Dev PC
AGENT_VERSION=1.1.0

GATEWAY_WS_URL=wss://gateway.example.com/agent/ws
AGENT_KEY=change-this-secret-min-32-chars
REPO_ROOTS_JSON=["/home/user/projects"]

LOG_LEVEL=info
MAX_OUTPUT_BYTES=200000
MAX_FILE_BYTES=2000000
MAX_SEARCH_MATCHES=2000
MAX_TREE_ENTRIES=50000

WS_PING_INTERVAL_MS=15000
WS_RECONNECT_MAX_MS=30000
WS_MAX_CONCURRENT_CALLS=4
RUNNER_TIMEOUT_MS=120000

ENABLE_GIT=true
ENABLE_RUNNER=false
ENABLE_DOCKER=false
ENABLE_HTTP_FETCH=false
ENABLE_SYSTEM_TOOLS=false
ENABLE_UNRESTRICTED_MODE=false
ENABLE_DATABASE=false
ENABLE_KUBERNETES=false
ENABLE_NETWORK=false
ENABLE_MCP_PROXY=false
ENABLE_CLI_TOOLS=false

RUNNER_ALLOWLIST_JSON=[]
RUNNER_CWD=./repo
REDACT_REGEXES_JSON=[]
LOG_ROOTS_JSON=[]
LOCAL_HTTP_ALLOWLIST_JSON=[]
DOCKER_SOCKET_PATH=/var/run/docker.sock

AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=/var/log/helix-agent

DASHBOARD_ENABLED=false
DASHBOARD_PORT=3001
DASHBOARD_AUTH_TOKEN=

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
